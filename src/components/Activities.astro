---
import { siteConfig } from "../config";
const hasActivities = siteConfig.activities && siteConfig.activities.length > 0;
---

{
  hasActivities && (
    <section id="activities" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Extra-Curricular Activities
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="flex flex-wrap gap-3">
              {siteConfig.activities.map((activity) => (
                <span class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm sm:text-base font-medium">
                  {activity}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
