---
import { siteConfig } from "../config";

const skills = siteConfig.skills;
const hasSkills =
  skills &&
  (skills.technical?.length || skills.it?.length || skills.soft?.length);
---

{
  hasSkills && (
    <section id="skills" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Skills
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8 space-y-8">
            <div class="grid gap-6 sm:grid-cols-2">
              <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-5 md:p-6">
                <h3 class="text-lg sm:text-xl font-semibold text-gray-900 mb-4">
                  Technical Skills
                </h3>
                <ul class="space-y-2">
                  {skills.technical?.map((skill) => (
                    <li class="flex items-start">
                      <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-400 mt-2 mr-3 flex-shrink-0" />
                      <span class="text-sm sm:text-base text-gray-600">
                        {skill}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-5 md:p-6">
                <h3 class="text-lg sm:text-xl font-semibold text-gray-900 mb-4">
                  IT Skills
                </h3>
                <ul class="space-y-2">
                  {skills.it?.map((skill) => (
                    <li class="flex items-start">
                      <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-400 mt-2 mr-3 flex-shrink-0" />
                      <span class="text-sm sm:text-base text-gray-600">
                        {skill}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-5 md:p-6">
              <h3 class="text-lg sm:text-xl font-semibold text-gray-900 mb-4">
                Soft Skills
              </h3>
              <ul class="space-y-2">
                {skills.soft?.map((skill) => (
                  <li class="flex items-start">
                    <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-400 mt-2 mr-3 flex-shrink-0" />
                    <span class="text-sm sm:text-base text-gray-600">
                      {skill}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
