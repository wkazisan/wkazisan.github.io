---
import { siteConfig } from "../config";
const hasTraining = siteConfig.trainings && siteConfig.trainings.length > 0;
---

{
  hasTraining && (
    <section id="training" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Training & Certificates
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8 space-y-4">
            {siteConfig.trainings.map((training) => (
              <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-5 md:p-6 hover:shadow-md transition-shadow duration-300">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                  <div>
                    <h3 class="text-lg sm:text-xl font-semibold text-gray-900">
                      {training.name}
                    </h3>
                    <p
                      class="text-sm sm:text-base"
                      style={`color: ${siteConfig.accentColor}`}
                    >
                      {training.issuer}
                    </p>
                  </div>
                  <span class="text-xs sm:text-sm text-gray-500">
                    {training.date}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}
